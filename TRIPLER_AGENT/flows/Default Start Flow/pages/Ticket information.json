{
  "name": "9479f2cb-cc9b-4ca0-ac19-6e0005238aa9",
  "displayName": "Ticket information",
  "form": {
    "parameters": [ {
      "displayName": "departure_city",
      "required": true,
      "entityType": "@sys.geo-city",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "messages": [ {
            "text": {
              "text": [ "What city would you like the flight to depart from?" ]
            },
            "languageCode": "en"
          } ]
        }
      }
    }, {
      "displayName": "departure_date",
      "required": true,
      "entityType": "@sys.date",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "messages": [ {
            "text": {
              "text": [ "What is the month and day of the departure?" ]
            },
            "languageCode": "en"
          } ]
        }
      }
    }, {
      "displayName": "destination_city",
      "required": true,
      "entityType": "@sys.geo-city",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "messages": [ {
            "text": {
              "text": [ "What is your destination city?" ]
            },
            "languageCode": "en"
          } ]
        }
      }
    }, {
      "displayName": "return_date",
      "required": true,
      "entityType": "@sys.date",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "messages": [ {
            "text": {
              "text": [ "What is the month and day for the returning flight?" ]
            },
            "languageCode": "en"
          } ]
        }
      }
    }, {
      "displayName": "passenger_name",
      "required": true,
      "entityType": "@sys.any",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "messages": [ {
            "text": {
              "text": [ "\tWhat is the passenger's name?" ]
            },
            "languageCode": "en"
          } ]
        }
      }
    } ]
  },
  "transitionRoutes": [ {
    "condition": "$page.params.status = \"FINAL\"",
    "triggerFulfillment": {
      "messages": [ {
        "text": {
          "text": [ "Thank you for that information. Let me check on the availability of your ticket" ]
        },
        "languageCode": "en"
      } ]
    },
    "targetPage": "Confirm trip",
    "name": "f98e94dc-8a2e-4dc6-9d3c-fb9cf51ff2d6"
  } ]
}
